# ── REQUIRED ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...          # ← PUT YOUR GROQ KEY HERE (free at console.groq.com)

# ── Database (auto-set by docker-compose, only change for local dev) ──
DATABASE_URL=postgresql://aeroops:aeroops@db:5432/aeroops

# ── Optional overrides ───────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2
